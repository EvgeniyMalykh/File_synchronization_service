[sync]
# Путь к синхронизируемой папке на локальном компьютере
local_folder = /path/to/local/folder

# Имя папки в облачном хранилище (Яндекс.Диск)
cloud_folder = /backup

# Токен доступа к облачному хранилищу (OAuth-токен Яндекс.Диска)
token = YOUR_TOKEN_HERE

# Период синхронизации в секундах
sync_period = 60

# Путь к файлу лога
log_file = sync.log
